# Backend API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Stellar Explorer URL
NEXT_PUBLIC_STELLAR_EXPLORER_BASE_URL=https://stellar.expert/explorer/testnet/tx

# Authentication Configuration
